# tooie-tmux widget theme overrides
# Copy to theme.conf and adjust.

TMUX_TOOIE_WIDGET_TTL=3
TMUX_TOOIE_WIDGET_QUERY_TIMEOUT=1

TMUX_TOOIE_EMPTY_COLOR="#5f5f87"
TMUX_TOOIE_RAM_COLOR="#ffb86c"
TMUX_TOOIE_SEP_COLOR="#6b7089"

TMUX_TOOIE_METER_1_COLOR="#ff5f5f"
TMUX_TOOIE_METER_2_COLOR="#ff875f"
TMUX_TOOIE_METER_3_COLOR="#ffd75f"
TMUX_TOOIE_METER_4_COLOR="#a4e84a"
TMUX_TOOIE_METER_5_COLOR="#6ee7a2"
TMUX_TOOIE_METER_6_COLOR="#34d399"

TMUX_TOOIE_BAT_FULL_ICON=""
TMUX_TOOIE_BAT_EMPTY_ICON=""
TMUX_TOOIE_BAT_CHARGING_ICON=" 󱈑"
