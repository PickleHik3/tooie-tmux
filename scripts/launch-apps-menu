#!/data/data/com.termux/files/usr/bin/sh

# Show launcher menu for Android apps from tmux.
# Usage:
#   launch-apps-menu.sh mouse   # open at mouse location
#   launch-apps-menu.sh key     # open at a fixed visible location

mode="${1:-key}"
mx="$2"
my="$3"

if [ "$mode" = "mouse" ]; then
  if [ -n "$mx" ] && [ -n "$my" ]; then
    x="$mx"
    y="$my"
  else
    x="M"
    y="M"
  fi
else
  # Keyboard fallback: place menu near the right side of current pane.
  x="R"
  y="P"
fi

tmux display-menu -T " Apps" -x "$x" -y "$y" \
  "YouTube 󰗃" y "display-message -d 1200 '#[fg=#f4bf75,bold]Opening YouTube 󰗃'; run-shell 'am start -n app.revanced.android.youtube/com.google.android.youtube.app.honeycomb.Shell\\\$HomeActivity > /dev/null 2>&1'" \
  "Browser 󰖟" b "display-message -d 1200 '#[fg=#f4bf75,bold]Opening Browser 󰖟'; run-shell 'am start -n com.brave.browser_nightly/com.google.android.apps.chrome.Main > /dev/null 2>&1'" \
  "WhatsApp 󰖣" w "display-message -d 1200 '#[fg=#f4bf75,bold]Opening WhatsApp 󰖣'; run-shell 'am start -n com.whatsapp/com.whatsapp.Main > /dev/null 2>&1'" \
  "Mihon 󰄛" t "display-message -d 1200 '#[fg=#f4bf75,bold]Opening Mihon 󰄛'; run-shell 'am start -n app.mihon/eu.kanade.tachiyomi.ui.main.MainActivity > /dev/null 2>&1'" \
  "Solid Explorer 󰉋" f "display-message -d 1200 '#[fg=#f4bf75,bold]Opening Solid Explorer 󰉋'; run-shell 'am start -n pl.solidexplorer2/pl.solidexplorer.SolidExplorer > /dev/null 2>&1'" \
  "Settings 󰒓" s "display-message -d 1200 '#[fg=#f4bf75,bold]Opening Settings 󰒓'; run-shell 'am start -n com.android.settings/com.android.settings.Settings > /dev/null 2>&1'" \
  "App Search 󱡴" l "display-message -d 1200 '#[fg=#f4bf75,bold]Opening App Search 󱡴'; run-shell 'am start -n net.nhiroki.bluelineconsole/net.nhiroki.bluelineconsole.applicationMain.MainActivity > /dev/null 2>&1'" \
  "Lock Screen 󰌾" z "display-message -d 1200 '#[fg=#f4bf75,bold]Opening Lock Screen 󰌾'; run-shell 'am start -n com.tiendnm.zukulock/com.tiendnm.zukulock.MainActivity > /dev/null 2>&1'"
